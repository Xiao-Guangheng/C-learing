{
    "tasks": [
        {
            "label": "Create Configured Build Dir",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "if not exist \"${workspaceFolder}\\build\" mkdir \"${workspaceFolder}\\build\""
            ],
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "dependsOn": "Create Configured Build Dir",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/utf-8",
                "/Fo${workspaceFolder}\\build\\",
                "/Fd${workspaceFolder}\\build\\",
                "/Fe${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe",
                "${fileDirname}\\*.cpp"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}